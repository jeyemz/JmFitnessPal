# Database Configuration
# Copy this file to .env and update the values.
# If you have an existing DB, run: database/migrations/001_add_nickname_and_activity.sql (see database/migrations/README.md)

# Frontend: optional. If set, API requests use this base URL (e.g. http://127.0.0.1:5000/api).
# If unset, the app uses same-origin /api (Vite proxies /api to the backend in dev; use nginx etc. in prod).
# VITE_API_URL=http://127.0.0.1:5000/api

# MySQL Root Password
MYSQL_ROOT_PASSWORD=rootpassword123

# Application Database User
MYSQL_USER=jmfitness_user
MYSQL_PASSWORD=jmfitness_pass123

# Database Name (do not change)
MYSQL_DATABASE=jmfitnesspal

# Connection Settings (for your application)
DB_HOST=localhost
DB_PORT=3306

# USDA FoodData Central API Configuration
# Get your free API key at: https://fdc.nal.usda.gov/api-key-signup.html
USDA_FDC_API_KEY=your-usda-fdc-api-key-here
USDA_FDC_BASE_URL=https://api.nal.usda.gov/fdc/v1

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
