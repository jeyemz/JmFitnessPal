# Database Configuration
# Copy this file to .env and update the values

# MySQL Root Password
MYSQL_ROOT_PASSWORD=rootpassword123

# Application Database User
MYSQL_USER=jmfitness_user
MYSQL_PASSWORD=jmfitness_pass123

# Database Name (do not change)
MYSQL_DATABASE=jmfitnesspal

# Connection Settings (for your application)
DB_HOST=localhost
DB_PORT=3306

# API Ninjas Configuration (Get your key at https://api-ninjas.com)
API_NINJAS_KEY=your-api-ninjas-key-here
API_NINJAS_BASE_URL=https://api.api-ninjas.com/v1

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
